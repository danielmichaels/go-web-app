#----------------------------------------
# App
#----------------------------------------
CGO_ENABLED=0

#----------------------------------------
# Server
#----------------------------------------
SERVER_PORT=9898
SERVER_TIMEOUT_READ=5s
SERVER_TIMEOUT_WRITE=10s
SERVER_TIMEOUT_IDLE=15s
X_API_KEY=changeme

#----------------------------------------
# Logging
#----------------------------------------
LOG_LEVEL=debug
LOG_JSON=false
LOG_CONCISE=false
LOG_REQUEST_HEADERS=true
LOG_RESPONSE_HEADERS=false

#----------------------------------------
# Rate Limiter
#----------------------------------------
RATE_LIMIT_ENABLED=true
RATE_LIMIT_RPS=10
RATE_LIMIT_BACKOFF=20s

{% if cookiecutter.database_choice == 'sqlite' -%}
#----------------------------------------
# SQLite
#----------------------------------------
DATABASE_URL=database/data.db
DATABASE_CONNECTION_CONTEXT=15s

#----------------------------------------
# Litestream
#----------------------------------------
LITESTREAM_LOCAL_DB_NAME_PATH=./database/data.db
DB_SYNC_INTERVAL=10s
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_DB_URL=s3://
{% endif -%}
{% if cookiecutter.database_choice == 'postgres' -%}
#----------------------------------------
# PostgreSQL
#----------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=db
POSTGRES_USER=dbuser
POSTGRES_PASSWORD=dbuser
POSTGRES_SSL_MODE=disable
POSTGRES_MAX_CONNS=16
{% endif -%}
{% if cookiecutter.use_nats -%}
#----------------------------------------
# NATS
#----------------------------------------
{% if not cookiecutter.embed_nats -%}
NATS_URL=nats://localhost:4222
{% endif -%}
NATS_TIMEOUT=10s
{% if cookiecutter.embed_nats -%}
NATS_STORE_DIR=data/jetstream
NATS_EMBED_PORT=0
{% endif -%}
{% endif -%}
